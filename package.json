{
  "name": "pomikit-ui",
  "version": "0.2.0",
  "description": "Beautiful by default. Components that understand your intent. — Intelligent Design System for Vue 3",
  "type": "module",
  "author": "",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "ui",
    "components",
    "pomikit"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/pomikit-ui.umd.cjs",
  "module": "./dist/pomikit-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pomikit-ui.js",
      "require": "./dist/pomikit-ui.umd.cjs"
    },
    "./styles.css": "./dist/pomikit-ui.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "reka-ui": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-links": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/test": "8.6.18",
    "@storybook/vue3": "8.6.18",
    "@storybook/vue3-vite": "8.6.18",
    "@types/node": "^22.15.30",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.1.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "storybook": "8.6.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "1.6.3",
    "vitest": "^3.2.1",
    "vue": "^3.5.16",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.10"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  }
}
