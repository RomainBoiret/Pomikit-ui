# Ignore all local/dot tooling by default
.*
!.github/
!.github/**
!.vscode/
!.vscode/**
!.gitignore

# Keep shared project config that starts with a dot
!.prettierignore
!.prettierrc.json
!.storybook/
!.storybook/**

# Dependencies
node_modules

# Builds / caches
dist
docs/.vitepress/dist
docs/.vitepress/cache
storybook-static
coverage
*.tsbuildinfo
*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env (also covered by .*, kept explicit)
.env
.env.*
!.env.example

# Editors / OS leftovers
.idea
.DS_Store
Thumbs.db
Desktop.ini
*~

# Test / tooling artifacts
playwright-report
test-results
blob-report
